{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://axtp.dev/schemas/conformance-case.schema.json",
  "type": "object",
  "required": ["id", "title", "since", "level", "profiles", "given"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(\\.[a-z0-9_]+)+$" },
    "title": { "type": "string", "minLength": 1 },
    "since": { "type": "string", "pattern": "^spec/v[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "level": { "type": "string", "minLength": 1 },
    "semantic": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "pattern": "^[a-z][a-z0-9_]+$" },
        "requiredRows": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 },
      "uniqueItems": true
    },
    "given": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "device_profile": { "type": "string", "minLength": 1 },
        "method": { "type": "string", "minLength": 1 },
        "transport": { "type": "string", "minLength": 1 }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/step" }
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/scenario" }
    },
    "assertions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "oneOf": [
    { "required": ["steps", "assertions"] },
    { "required": ["scenarios"] }
  ],
  "$defs": {
    "direction": {
      "type": "string",
      "enum": ["client_to_server", "server_to_client", "peer_to_runtime", "client_observes", "runtime_local"]
    },
    "statusCode": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "required": ["oneOf"],
          "additionalProperties": false,
          "properties": {
            "oneOf": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 },
              "uniqueItems": true
            }
          }
        }
      ]
    },
    "typeExpectation": {
      "oneOf": [
        { "type": "string" },
        { "type": "number" },
        { "type": "boolean" },
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "type": { "type": "string", "minLength": 1 },
            "gt": { "type": "number" },
            "gte": { "type": "number" },
            "minLength": { "type": "integer", "minimum": 0 },
            "oneOf": {
              "type": "array",
              "minItems": 1,
              "items": { "type": ["string", "number", "boolean"] }
            }
          }
        },
        {
          "type": "array",
          "items": { "$ref": "#/$defs/typeExpectation" }
        }
      ]
    },
    "rpc": {
      "type": "object",
      "required": ["op", "requestId"],
      "additionalProperties": false,
      "properties": {
        "encoding": { "type": "string", "minLength": 1 },
        "op": { "type": "string", "minLength": 1 },
        "requestId": { "type": "integer", "minimum": 0 },
        "method": { "type": "string", "minLength": 1 },
        "params": { "type": "object", "additionalProperties": true }
      }
    },
    "expectRpc": {
      "type": "object",
      "required": ["op"],
      "additionalProperties": false,
      "properties": {
        "encoding": { "type": "string", "minLength": 1 },
        "op": { "type": "string", "minLength": 1 },
        "requestId": { "type": "integer", "minimum": 0 },
        "statusCode": { "$ref": "#/$defs/statusCode" },
        "result": { "type": "object", "additionalProperties": { "$ref": "#/$defs/typeExpectation" } }
      }
    },
    "jsonrpc": {
      "type": "object",
      "required": ["op"],
      "additionalProperties": false,
      "properties": {
        "sid": {
          "oneOf": [
            { "type": "string" },
            { "$ref": "#/$defs/valueReference" }
          ]
        },
        "op": { "type": "string", "minLength": 1 },
        "d": { "type": "object", "additionalProperties": true }
      }
    },
    "valueReference": {
      "type": "object",
      "required": ["ref"],
      "additionalProperties": false,
      "properties": {
        "ref": { "type": "string", "pattern": "^[a-z][a-zA-Z0-9_]*\\.[a-z][a-zA-Z0-9_]*$" }
      }
    },
    "expectJsonrpc": {
      "type": "object",
      "required": ["op"],
      "additionalProperties": false,
      "properties": {
        "sid": { "$ref": "#/$defs/typeExpectation" },
        "op": { "type": "string", "minLength": 1 },
        "d": { "type": "object", "additionalProperties": true }
      }
    },
    "control": {
      "type": "object",
      "required": ["type", "controlId"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "minLength": 1 },
        "controlId": { "type": "integer", "minimum": 0 },
        "statusCode": { "$ref": "#/$defs/statusCode" }
      }
    },
    "stream": {
      "type": "object",
      "required": ["streamId", "seqId", "cursor", "data"],
      "additionalProperties": false,
      "properties": {
        "streamId": { "type": "integer", "minimum": 0 },
        "seqId": { "type": "integer", "minimum": 0 },
        "cursor": { "type": "integer", "minimum": 0 },
        "data": { "type": "string", "pattern": "^[0-9A-Fa-f]*$" }
      }
    },
    "event": {
      "type": "object",
      "required": ["name", "data"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "data": { "type": "object", "additionalProperties": true }
      }
    },
    "error": {
      "type": "object",
      "required": ["requestId", "code"],
      "additionalProperties": false,
      "properties": {
        "requestId": { "type": "integer", "minimum": 0 },
        "code": { "type": "string", "minLength": 1 }
      }
    },
    "registryLookup": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "capability": { "type": "string", "minLength": 1 },
        "methods": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      }
    },
    "expect": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "rpc": { "$ref": "#/$defs/expectRpc" },
        "jsonrpc": { "$ref": "#/$defs/expectJsonrpc" },
        "control": { "$ref": "#/$defs/control" },
        "stream": { "$ref": "#/$defs/stream" },
        "event": {
          "type": "object",
          "required": ["name"],
          "additionalProperties": true,
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "data": { "type": "object", "additionalProperties": true }
          }
        },
        "error": {
          "type": "object",
          "required": ["requestId", "code", "ok"],
          "additionalProperties": false,
          "properties": {
            "requestId": { "type": "integer", "minimum": 0 },
            "code": { "type": "string", "minLength": 1 },
            "ok": { "type": "boolean" }
          }
        },
        "methods": { "type": "object", "additionalProperties": true },
        "capability": { "type": "object", "additionalProperties": true },
        "wire": { "type": "object", "additionalProperties": true },
        "compatibility_input": {
          "type": "object",
          "required": ["kind", "outcome", "applicationDispatched", "sessionState"],
          "additionalProperties": false,
          "properties": {
            "kind": { "type": "string", "minLength": 1 },
            "outcome": { "$ref": "#/$defs/typeExpectation" },
            "applicationDispatched": { "type": "boolean" },
            "sessionState": { "type": "string", "minLength": 1 }
          }
        },
        "no_event": {
          "type": "object",
          "required": ["name", "withinMs"],
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "withinMs": { "type": "integer", "minimum": 1, "maximum": 10000 }
          }
        }
      },
      "minProperties": 1
    },
    "scenario": {
      "type": "object",
      "required": ["name", "given", "steps", "assertions"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "given": {
          "type": "object",
          "required": ["client_axtp_version"],
          "additionalProperties": true,
          "properties": {
            "client_axtp_version": { "type": "string", "minLength": 1 }
          }
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/step" }
        },
        "assertions": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "step": {
      "type": "object",
      "required": ["direction"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "role": { "type": "string", "enum": ["precondition", "input", "trigger", "degraded", "observe", "liveness"] },
        "captureAs": { "type": "string", "pattern": "^[a-z][a-zA-Z0-9_]*$" },
        "responseTo": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "triggeredBy": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
        "direction": { "$ref": "#/$defs/direction" },
        "rpc": { "$ref": "#/$defs/rpc" },
        "jsonrpc": { "$ref": "#/$defs/jsonrpc" },
        "control": { "$ref": "#/$defs/control" },
        "stream": { "$ref": "#/$defs/stream" },
        "event": { "$ref": "#/$defs/event" },
        "error": { "$ref": "#/$defs/error" },
        "registry_lookup": { "$ref": "#/$defs/registryLookup" },
        "expect": { "$ref": "#/$defs/expect" }
      },
      "oneOf": [
        { "required": ["rpc"] },
        { "required": ["jsonrpc"] },
        { "required": ["control"] },
        { "required": ["stream"] },
        { "required": ["event"] },
        { "required": ["error"] },
        { "required": ["registry_lookup"] },
        { "required": ["expect"] }
      ],
      "allOf": [
        {
          "if": { "required": ["captureAs"] },
          "then": { "required": ["expect"] }
        }
      ]
    }
  }
}
