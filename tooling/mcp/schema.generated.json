    {
      "name": "StreamHidMediaCapability",
      "type": "object",
      "description": "Describes HID-backed media STREAM support.",
      "fields": [
        {
          "id": 1,
          "name": "transportProfile",
          "type": "string",
          "required": true,
          "deprecated": false,
          "maxLength": 32,
          "description": "Supported HID Transport Profile, usually AXTP-USB-HID."
        },
        {
          "id": 2,
          "name": "maxStreamCount",
          "type": "uint8",
          "required": true,
          "deprecated": false,
          "description": "Maximum simultaneously opened media streams."
        },
        {
          "id": 3,
          "name": "maxChunkSize",
          "type": "uint16",
          "required": true,
          "deprecated": false,
          "description": "Maximum STREAM data bytes per Standard Frame after the 16B STREAM header."
        },
        {
          "id": 4,
          "name": "supportsVideo",
          "type": "bool",
          "required": true,
          "deprecated": false,
          "description": "Device can open media.video streams over HID."
        },
        {
          "id": 5,
          "name": "supportsAudio",
          "type": "bool",
          "required": true,
          "deprecated": false,
          "description": "Device can open media.audio streams over HID."
        }
      ]
    },
    {
      "name": "NetworkGetApInfoRequest",
      "type": "object",
      "description": "Empty request for querying the device-hosted SoftAP information.",
      "fields": []
    },
    {
      "name": "NetworkGetApInfoResponse",
      "type": "object",
      "description": "Current device-hosted SoftAP information.",
      "fields": [
        {
          "id": 1,
          "name": "enabled",
          "type": "bool",
          "required": true,
          "deprecated": false,
          "description": "Whether the device-hosted SoftAP is currently enabled."
        },
        {
          "id": 2,
          "name": "ssid",
          "type": "string",
          "required": false,
          "deprecated": false,
          "maxLength": 32,
          "description": "SoftAP SSID advertised by the device."
        },
        {
          "id": 3,
          "name": "bssid",
          "type": "string",
          "required": false,
          "deprecated": false,
          "maxLength": 17,
          "description": "SoftAP BSSID or MAC address in colon-separated form."
        },
        {
          "id": 4,
          "name": "band",
          "type": "enum",
          "required": false,
          "deprecated": false,
          "description": "SoftAP radio band, such as 2.4GHz, 5GHz or 6GHz."
        },
        {
          "id": 5,
          "name": "channel",
          "type": "uint16",
          "required": false,
          "deprecated": false,
          "min": 1,
          "max": 233,
          "description": "Wi-Fi channel used by the SoftAP."
        },
        {
          "id": 6,
          "name": "security",
          "type": "enum",
          "required": false,
          "deprecated": false,
          "description": "SoftAP security mode, such as open, wpa2_psk or wpa3_sae."
        },
        {
          "id": 7,
          "name": "ipAddress",
          "type": "string",
          "required": false,
          "deprecated": false,
          "maxLength": 45,
          "description": "IPv4 or IPv6 address assigned to the device on the SoftAP interface."
        },
        {
          "id": 8,
          "name": "clientCount",
          "type": "uint16",
          "required": false,
          "deprecated": false,
          "description": "Number of clients currently associated with the SoftAP."
        }
      ]
    },
