        {
          "id": 6,
          "name": "resumeToken",
          "type": "bytes",
          "required": false,
          "deprecated": false,
          "maxLength": 32,
          "description": "Opaque resume token."
        },
        {
          "id": 7,
          "name": "otaState",
          "type": "enum",
          "required": true,
          "deprecated": false,
          "description": "Current OTA state."
        },
        {
          "id": 8,
          "name": "profile",
          "type": "string",
          "required": true,
          "deprecated": false,
          "maxLength": 32,
          "description": "Bound Stream Profile, usually firmware.ota."
        },
        {
          "id": 9,
          "name": "ackMode",
          "type": "enum",
          "required": true,
          "deprecated": false,
          "description": "Stream-layer reliability mode."
        },
        {
          "id": 10,
          "name": "cursorUnit",
          "type": "enum",
          "required": true,
          "deprecated": false,
          "description": "Cursor unit used by STREAM packets, usually byteOffset."
        },
        {
          "id": 11,
          "name": "maxDataSize",
          "type": "uint16",
          "required": false,
          "deprecated": false,
          "description": "Maximum STREAM data bytes per packet."
        }
      ]
    },
