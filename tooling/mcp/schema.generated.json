    {
      "name": "StreamOpenRequest",
      "type": "object",
      "description": "Parameters for opening a HID-backed media STREAM channel.",
      "fields": [
        {
          "id": 1,
          "name": "profile",
          "type": "string",
          "required": true,
          "deprecated": false,
          "maxLength": 32,
          "description": "Stream Profile name. For this method use media.video or media.audio."
        },
        {
          "id": 2,
          "name": "transportProfile",
          "type": "string",
          "required": true,
          "deprecated": false,
          "maxLength": 32,
          "description": "Transport Profile name. HID media streams use AXTP-USB-HID."
        },
        {
          "id": 3,
          "name": "direction",
          "type": "enum",
          "required": true,
          "deprecated": false,
          "description": "Stream direction; values are device_to_host, host_to_device, or bidirectional."
        },
        {
          "id": 4,
          "name": "mediaKind",
          "type": "enum",
          "required": true,
          "deprecated": false,
          "description": "Media kind carried by this stream; values are video or audio."
        },
        {
          "id": 5,
          "name": "sourceId",
          "type": "uint16",
          "required": false,
          "deprecated": false,
          "description": "Device-local media source identifier."
        },
        {
          "id": 6,
          "name": "codec",
          "type": "string",
          "required": true,
          "deprecated": false,
          "maxLength": 32,
          "description": "Codec or sample format, for example h264, mjpeg, pcm_s16le, or opus."
        },
        {
          "id": 7,
          "name": "width",
          "type": "uint16",
          "required": false,
          "deprecated": false,
          "description": "Video width in pixels. Required for video streams when not implied by sourceId."
        },
        {
          "id": 8,
          "name": "height",
          "type": "uint16",
          "required": false,
          "deprecated": false,
          "description": "Video height in pixels. Required for video streams when not implied by sourceId."
        },
        {
          "id": 9,
          "name": "frameRate",
          "type": "uint16",
          "required": false,
          "deprecated": false,
          "description": "Video frame rate in frames per second."
        },
        {
          "id": 10,
          "name": "sampleRate",
          "type": "uint32",
          "required": false,
          "deprecated": false,
          "description": "Audio sample rate in Hz."
        },
        {
          "id": 11,
          "name": "channelCount",
          "type": "uint8",
          "required": false,
          "deprecated": false,
          "description": "Number of audio channels."
        },
        {
