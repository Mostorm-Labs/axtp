    {
      "name": "FirmwareBeginRequest",
      "type": "object",
      "fields": [
        {
          "id": 1,
          "name": "imageType",
          "type": "enum",
          "required": true,
          "deprecated": false,
          "description": "Firmware image type."
        },
        {
          "id": 2,
          "name": "imageSize",
          "type": "uint64",
          "required": true,
          "deprecated": false,
          "description": "Full firmware image size in bytes."
        },
        {
          "id": 3,
          "name": "imageVersion",
          "type": "string",
          "required": true,
          "deprecated": false,
          "maxLength": 32,
          "description": "Target firmware version."
        },
        {
          "id": 4,
          "name": "verifyType",
          "type": "string",
          "required": true,
          "deprecated": false,
          "maxLength": 16,
          "description": "Object-level verification algorithm such as md5, crc32 or sha256."
        },
        {
          "id": 5,
          "name": "verifyValue",
          "type": "string",
          "required": true,
          "deprecated": false,
          "maxLength": 64,
          "description": "Hex verification value for the full firmware image."
        },
        {
          "id": 6,
          "name": "chunkSizeHint",
          "type": "uint16",
          "required": false,
          "deprecated": false,
          "description": "Preferred STREAM chunk size in bytes."
        },
        {
          "id": 7,
          "name": "windowSizeHint",
          "type": "uint16",
          "required": false,
          "deprecated": false,
          "description": "Preferred stream-layer send window."
        },
        {
          "id": 8,
          "name": "flags",
          "type": "uint16",
          "required": false,
          "deprecated": false,
          "description": "OTA behavior flags such as resume or force-update hints."
        }
      ]
    },
    {
