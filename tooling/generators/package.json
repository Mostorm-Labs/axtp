{
  "name": "@axtp/spec-generator",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "axtp-gen": "./dist/cli.js"
  },
  "scripts": {
    "axtp-gen": "node dist/cli.js",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "validate": "node dist/cli.js validate --spec ../..",
    "validate:sources": "node dist/cli.js validate-sources --spec ../..",
    "build:protocol": "node dist/cli.js build-protocol --spec ../..",
    "emit:protocol": "node dist/cli.js emit-protocol --spec ../..",
    "generate": "node dist/cli.js generate --spec ../..",
    "generate:registry": "node dist/cli.js generate-registry --spec ../..",
    "validate:protocol": "node dist/cli.js validate-protocol --spec ../..",
    "generate:protocol": "node dist/cli.js generate-protocol --spec ../.."
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "commander": "^12.1.0",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@11.3.0"
}
