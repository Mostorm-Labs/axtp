{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://axtp.dev/schemas/conformance-case.schema.json",
  "type": "object",
  "required": ["id", "title", "since", "level", "profiles", "steps", "assertions"],
  "additionalProperties": true,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(\\.[a-z0-9_]+)+$" },
    "title": { "type": "string", "minLength": 1 },
    "since": { "type": "string", "pattern": "^spec/v[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "level": { "type": "string", "minLength": 1 },
    "profiles": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "given": { "type": "object" },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "object" }
    },
    "assertions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "expected": { "type": "object" }
  }
}
